# hodlbook configuration -- copy to `.env` and adjust.
# Every variable is optional; the value shown is the default used when unset.
# All variables are prefixed with HODLBOOK_.

# DynamoDB single-table name.
HODLBOOK_TABLE_NAME=hodlbook

# AWS region for the DynamoDB client.
HODLBOOK_AWS_REGION=us-east-1

# Optional DynamoDB endpoint override (e.g. DynamoDB Local). Leave unset for AWS.
# HODLBOOK_DYNAMODB_ENDPOINT=http://localhost:8000

# Price source: "mock" (deterministic, offline) or "http" (CoinGecko).
HODLBOOK_PRICE_PROVIDER=mock

# Freshness window, in seconds, for cached price ticks.
HODLBOOK_PRICE_TTL_SECONDS=60

# Default cash balance for newly created portfolios.
HODLBOOK_DEFAULT_STARTING_CASH=100000

# Root log level: DEBUG | INFO | WARNING | ERROR | CRITICAL.
HODLBOOK_LOG_LEVEL=INFO
